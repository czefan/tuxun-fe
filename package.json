    "build:quickapp-webview-union": "uni build -p quickapp-webview-union",
    "upload:changeset": "pnpm changeset && pnpm changeset version",
    "upload:mp": "node ./scripts/upload-weixin.js",
    "check:assets": "node ./scripts/check-static-assets.js",
    "type-check": "vue-tsc --noEmit",
    "lint:quick": "oxlint",
    "lint:eslint": "eslint --cache --cache-location .eslintcache",
    "lint": "node ./scripts/run-checks.js lint:quick lint:eslint",
    "lint:fix": "oxlint --fix && eslint --fix",
    "fmt": "oxfmt --write \"**/*.{css,scss,html,json,jsonc,md}\" --no-error-on-unmatched-pattern",
    "fmt:check": "oxfmt --check \"**/*.{css,scss,html,json,jsonc,md}\" --no-error-on-unmatched-pattern",
    "test": "vitest",
    "test:run": "vitest run",
    "check:parallel": "node ./scripts/run-checks.js check:assets lint:quick lint:eslint type-check test:run",
    "check": "pnpm check:assets && pnpm lint:quick && pnpm lint:eslint && pnpm type-check && pnpm test:run"
