{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "always",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "endOfLine": "lf",
  "htmlWhitespaceSensitivity": "css",
  "insertFinalNewline": true,
  "objectWrap": "preserve",
  "printWidth": 100,
  "proseWrap": "preserve",
  "quoteProps": "as-needed",
  "semi": false,
  "singleAttributePerLine": false,
  "singleQuote": true,
  "sortImports": false,
  "sortPackageJson": false,
  "sortTailwindcss": false,
  "tabWidth": 2,
  "trailingComma": "all",
  "useTabs": false,
  "vueIndentScriptAndStyle": false,
  "ignorePatterns": [
    ".agents/**",
    ".trae/**",
    ".vscode/**",
    "dist/**",
    "node_modules/**",
    "coverage/**",
    "**/uni_modules/**",
    "**/nativeplugins/**",
    "auto-import.d.ts",
    "uni-pages.d.ts",
    "src/pages.json",
    "src/manifest.json",
    "src/service/**",
    "pnpm-lock.yaml"
  ]
}
